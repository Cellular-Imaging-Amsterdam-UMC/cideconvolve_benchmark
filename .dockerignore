# Runtime inputs/outputs are mounted, not baked in
outfolder/
infolder/
gtfolder/

# Data is mounted at runtime, not baked in
data/
localdata/

# Windows binaries (Linux builds deconwolf from source)
bin/dw.exe
bin/dw_bw.exe
bin/*.dll
bin/dl2classes/
bin/dl2stubs/
bin/dl2_sources.txt

# Git and IDE
.git/
.gitignore
.vscode/
.idea/
.codex/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# vcpkg build artifacts
vcpkg/

# Runtime caches
VkFFT_kernelCache_*.binary
fftw_wisdom_*.dat

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Local app/editor state
.last_settings.json

# Local helper assets not used by the image build
tests/
scripts/
